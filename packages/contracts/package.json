{
  "name": "@sourceplane/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "schemas"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./src/node.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "contract:test": "vitest run test/contracts.test.ts",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "ajv": "^8",
    "ajv-formats": "^3",
    "yaml": "^2"
  }
}
