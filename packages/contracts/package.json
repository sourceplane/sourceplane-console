{
  "name": "@sourceplane/contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "dist",
    "schemas",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./src/api/index.ts",
      "import": "./dist/api/index.js"
    },
    "./auth": {
      "types": "./src/auth/index.ts",
      "import": "./dist/auth/index.js"
    },
    "./components": {
      "types": "./src/components/index.ts",
      "import": "./dist/components/index.js"
    },
    "./events": {
      "types": "./src/events/index.ts",
      "import": "./dist/events/index.js"
    },
    "./fixtures": {
      "types": "./src/fixtures/index.ts",
      "import": "./dist/fixtures/index.js"
    },
    "./membership": {
      "types": "./src/membership/index.ts",
      "import": "./dist/membership/index.js"
    },
    "./node": {
      "types": "./src/node.ts",
      "import": "./dist/node.js"
    },
    "./projects": {
      "types": "./src/projects/index.ts",
      "import": "./dist/projects/index.js"
    },
    "./resources": {
      "types": "./src/resources/index.ts",
      "import": "./dist/resources/index.js"
    },
    "./schemas/*": "./schemas/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "contract:test": "vitest run test/contracts.test.ts test/public-api.test.ts",
    "lint": "eslint src test",
    "test": "vitest run test/contracts.test.ts test/public-api.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "yaml": "^2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "ajv": "^8",
    "ajv-formats": "^3"
  }
}
