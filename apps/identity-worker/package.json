{
  "name": "@sourceplane/identity-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "deploy": "node ../../tooling/scripts/run-wrangler-deploy.mjs",
