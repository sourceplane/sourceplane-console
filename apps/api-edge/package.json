{
  "name": "@sourceplane/api-edge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "deploy": "node ../../tooling/scripts/run-wrangler-deploy.mjs",
    "dev": "wrangler dev --local",
    "lint": "eslint src",
    "test": "vitest run test/worker.integration.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@sourceplane/contracts": "workspace:*",
    "@sourceplane/shared": "workspace:*"
  },
  "devDependencies": {
    "@sourceplane/identity-worker": "workspace:*",
    "@sourceplane/testing": "workspace:*",
    "wrangler": "^4"
  }
}
