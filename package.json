{
  "name": "sourceplane-saas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.7.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "contract:test": "turbo run contract:test",
    "deploy": "turbo run deploy",
    "dev": "turbo run dev --parallel --filter=@sourceplane/api-edge --filter=@sourceplane/web-console",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4",
    "@eslint/js": "^9",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "globals": "^16",
    "prettier": "^3",
    "turbo": "^2",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vitest": "^3"
  }
}
